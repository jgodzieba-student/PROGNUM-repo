    "b = int(input(\"Enter 2nd boundary\"))\n",
    "\n",
    "n=1000\n",
    "x = np.random.uniform(a, b, n) \n",
    "y = eval(fun)\n",
    "\n",
    "y = np.array(y)\n",
    "\n",
    "i = ((b-a)/len(y))*sum(y)\n",
    "\n",
    "print(i)"
